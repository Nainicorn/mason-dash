<header class="header">
  <div class="header-logo-title">
    <div class="header-logo"></div>
    <div class="header-title">Mason<span>Dash</span></div>
  </div>
  <div class="header-user"></div>
  <div class="header-actions">
    <div class="theme-dropdown">
      <button class="theme-dropdown-toggle">
        <span class="theme-preview"></span>
        <span class="theme-label">Mason</span>
        <span class="theme-arrow">&#9662;</span>
      </button>
      <div class="theme-dropdown-menu">
        <div class="theme-option" data-theme="default">
          <span class="theme-swatch" style="background: #006633;"></span>
          <span class="theme-option-label" style="color: #e8edf2;">Mason</span>
        </div>
        <div class="theme-option" data-theme="light">
          <span class="theme-swatch" style="background: #ffffff;"></span>
          <span class="theme-option-label" style="color: #ffffff;">Light</span>
        </div>
        <div class="theme-option" data-theme="night">
          <span class="theme-swatch" style="background: #7c3aed;"></span>
          <span class="theme-option-label" style="color: #e2dff0;">Night</span>
        </div>
        <div class="theme-option" data-theme="sea">
          <span class="theme-swatch" style="background: #0ea5e9;"></span>
          <span class="theme-option-label" style="color: #ccd6f6;">Ocean</span>
        </div>
        <div class="theme-option" data-theme="evil">
          <span class="theme-swatch" style="background: #ef4444;"></span>
          <span class="theme-option-label" style="color: #e5e5e5;">Dark</span>
        </div>
      </div>
    </div>
    <button class="header-link" data-action="exit" title="Sign Out"></button>
  </div>
</header>
<section class="section">
  <div class="item courses" data-type="courses">
    <div class="item-header">
      <div class="item-title">Courses</div>
    </div>
    <div class="item-body"></div>
  </div>
  <div class="item info" data-type="info">
    <div class="item-header">
      <div class="item-title">Info</div>
    </div>
    <div class="item-body"></div>
  </div>
  <div class="item future" data-type="future">
    <div class="item-header">
      <div class="item-title">Future Schedule Builder</div>
      <div class="item-controls">
        <select></select>
      </div>
    </div>
    <div class="item-body"></div>
  </div>
  <div class="item map" data-type="map">
    <div class="item-header">
      <div class="item-title">Campus Map</div>
      <div class="item-controls">
        <select></select>
      </div>
    </div>
    <div class="item-body"></div>
  </div>
  <div class="item credits" data-type="credits">
    <div class="item-header">
      <div class="item-title">Progress</div>
    </div>
    <div class="item-body"></div>
  </div>
</section>
<footer class="footer">
  <p>&copy; 2024 Mason Dash &mdash; George Mason University</p>
</footer>